{
  "name": "agent-warden",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Neeraj1850/agent-warden.git"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "arc:fork:seed": "tsx scripts/seed-arc-fork.ts",
    "demo:arc-fork": "pnpm build && tsx scripts/arc-fork-demo.ts",
    "demo:mvp": "tsx scripts/mvp-demo.ts",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint && eslint .",
    "prepare": "husky",
    "test": "turbo run test && pnpm demo:mvp",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx,js,mjs,cjs}": "eslint --max-warnings=0"
  }
}
